#############################
# Frontend (Vite)
#############################
# Backend API base (must end with /api)
VITE_API_URL=http://localhost:5000/api

#############################
# Backend (Express) - server/.env
#############################
# MongoDB Connection String (required for server to start)
MONGODB_URI=mongodb://localhost:27017/legal-shathi

# OpenAI (used by document generation + AI document analysis)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# Optional: for Azure/OpenAI compatible endpoints
# OPENAI_BASE_URL=https://api.openai.com/v1

# CORS client URL (optional)
CLIENT_URL=http://localhost:8080
PORT=5000

# Cloudinary (optional - profile pictures)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
